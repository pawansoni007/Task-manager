# Copy to .env for local overrides. All values are optional.

# When unset, the app uses the in-memory repository (data resets on restart).
# Local SQLite example:   DATABASE_URL=sqlite:///./tasks.db
# Postgres (Render) example: DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# DATABASE_URL=

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
